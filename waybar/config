{
"layer": "top",
"position": "top",
"height": 30,
"margin-bottom":0,
"margin-top":0,

"modules-left": ["custom/archicon","sway/workspaces"],
"modules-center": ["clock"],
"modules-right":  ["temperature","pulseaudio","backlight","battery", "network", "memory","cpu", "tray", "sway/mode"],


// ********************************
// MODULES LEFT


"custom/archicon": {
    "format": "≤░μΘ" 
},

"sway/workspaces":{
  "disable-scroll": true
},


// *******************************
// MODULES CENTER

"clock":{
  "timezone": "America/Sao_Paulo",
  "format": "ΎΒ│  {:%a, %d %b  |  ≤░ξΦ  %H:%M}",
  "format-alt":"{:%a, %d %b  |  %H:%M}" // caso icons nao carreguem
},

// *******************************
// MODULES RIGHT

"temperature": {
  "format": "ΎΜΚ {temperatureC}┬░C",            
  "format-critical": "ΎΜΘ {temperatureC}┬░C",
  "interval": 1,
  "critical-threshold": 80,
  "on-click": "kitty -e htop"
},

"pulseaudio":{
  "format": "{icon} {volume}% {format_source}",
  "format-bluetooth": "{icon}≤░Γψ {volume}% {format_source}",
  "format-bluetooth-muted": "{icon}≤░Γ▓ {format_source}",
  "format-muted": "≤░ζθ {format_source}",
  "format-source": "≤░Ξυ {volume}% ",
  "format-source-muted": "≤░Ξφ",
  "format-icons": {
	  "headphone": "≤░ΜΜ",
	  "headset": "≤░ΜΟ",
	  "default": ["ΎΑο", "ΎΑπ", "ΎΑρ "]
  },
  "on-click": "pavucontrol"
},

"backlight":{
  "device": "intel_backlight",
  "format": "{icon} {percent}%",
  "format-icons": ["≤▒σΟ", "≤▒σΣ", "≤▒σΥ", "≤░δρ"]
},

"battery":{
  "states":{
	  "warning": 30,
	  "critical": 15
  },
  "format": "{icon} {capacity}%",
  "format-charging": "≤▒ΡΜ  {capacity}%",
  "format-plugged": "≤▒ΡΜ {capacity}%",
  "format-alt": "{capacity}%", // caso icons nao carreguem
  "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]

},

"sway/mode": {
    "format": "<span style=\"italic\">{}</span>"
},

"tray": {
    "icon-size": 16,
    "spacing": 6
},

"cpu": {
    "format": "ΎΜδ&#8239; {usage}%",
    "tooltip": false,
    "on-click": "kitty -e 'htop'"
},

"memory": {
    "interval": 30,
    "format": "ΎΔΚ  {used:0.2f}GB",
    "max-length": 10,
    "tooltip": false,
    "warning": 70,
    "critical": 90
},
"network": {
  "interval": 2,
  "format-wifi": "ΎΘτ  {signalStrength}%",
  "format-ethernet": "ΎΔΒ",
  "format-linked": " {ipaddr}",
  "format-disconnected": "ΎΒ▒  Disconnected",
  "format-disabled": "",
  "tooltip": false,
  "max-length": 20,
  "min-length": 6,
  "format-alt": "{essid}"
},

}
